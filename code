import cv2
import numpy as np
import matplotlib.pyplot as plt

# ------------------------------
# Function to analyze leaf health
# ------------------------------
def analyze_leaf(image_path):
    img = cv2.imread(image_path)

    if img is None:
        print("Error: Image not found!")
        return None, None, None, None, None

    # Resize for consistency
    img = cv2.resize(img, (300, 300))

    # Convert to HSV
    hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)

    # Define green color range (healthy leaves)
    lower_green = np.array([25, 40, 40])
    upper_green = np.array([90, 255, 255])

    # Define brown/yellow color range (diseased/unhealthy areas)
    # This range typically covers hues from red to yellow, with varying saturation and value
    lower_brown = np.array([10, 50, 40])
    upper_brown = np.array([30, 255, 200])

    # Mask green areas
    green_mask = cv2.inRange(hsv, lower_green, upper_green)

    # Mask brown/yellow areas
    brown_mask = cv2.inRange(hsv, lower_brown, upper_brown)

    # Calculate percentage of green area
    green_pixels = np.sum(green_mask > 0)
    total_pixels = img.shape[0] * img.shape[1]
    green_ratio = green_pixels / total_pixels

    # Calculate percentage of brown/yellow area
    brown_pixels = np.sum(brown_mask > 0)
    brown_ratio = brown_pixels / total_pixels

    return img, green_ratio, brown_ratio, green_mask, brown_mask

def decision_system(green_ratio, brown_ratio):

    # Thresholds (can be fine-tuned based on more data)
    SEVERE_BROWN_THRESHOLD = 0.15
    MODERATE_BROWN_THRESHOLD = 0.05
    HEALTHY_GREEN_THRESHOLD = 0.70
    MODERATE_GREEN_THRESHOLD = 0.50

    if brown_ratio > SEVERE_BROWN_THRESHOLD and green_ratio < MODERATE_GREEN_THRESHOLD:
        return "Severe Disease", "Spray strong pesticide", "25 ml"
    elif brown_ratio > MODERATE_BROWN_THRESHOLD or green_ratio < HEALTHY_GREEN_THRESHOLD:
        return "Moderate Disease", "Spray mild pesticide", "10 ml"
    else:
        return "Healthy", "No pesticide needed", "0 ml"


def run_simulation(image_path):

    img, green_ratio, brown_ratio, green_mask, brown_mask = analyze_leaf(image_path)

    if img is None:
        return

    status, action, amount = decision_system(green_ratio, brown_ratio)

    print("\n--- RESULT ---")
    print("Health Status:", status)
    print("Recommendation:", action)
    print("Pesticide Amount:", amount)
    print("Green Ratio:", round(green_ratio, 2))
    print("Brown Ratio:", round(brown_ratio, 2))

   
    fig, axes = plt.subplots(1, 3, figsize=(15, 5))

    axes[0].imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))
    axes[0].set_title(f"Original ({status})")
    axes[0].axis('off')

    axes[1].imshow(green_mask, cmap='gray')
    axes[1].set_title('Green Mask')
    axes[1].axis('off')

    axes[2].imshow(brown_mask, cmap='gray')
    axes[2].set_title('Brown Mask')
    axes[2].axis('off')

    plt.tight_layout()  
    plt.show()

run_simulation("input.jpg")
